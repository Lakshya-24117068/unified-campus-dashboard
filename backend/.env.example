# Google Gemini API key for the AI assistant. Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Model used by the AI assistant
# All models below run on the v1beta endpoint used by @google/genai SDK:
#   gemini-2.0-flash-lite  — 1500 req/day, 30 RPM  ← best free-tier throughput
#   gemini-2.0-flash       — 1500 req/day, 15 RPM
# Note: gemini-1.5-* models are NOT available on v1beta
GEMINI_MODEL=gemini-2.0-flash-lite

# Port the orchestrator backend listens on
PORT=4000

# URLs of the campus MCP servers (override if running on different hosts/ports)
LIBRARY_MCP_URL=http://localhost:4101/mcp
CAFETERIA_MCP_URL=http://localhost:4102/mcp
EVENTS_MCP_URL=http://localhost:4103/mcp
ACADEMICS_MCP_URL=http://localhost:4104/mcp
